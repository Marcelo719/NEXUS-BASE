# ─── WhatsApp Business API ───────────────────────────────────
WHATSAPP_TOKEN=              # Token de verificación del webhook (inventado por vos)
WHATSAPP_APP_SECRET=         # App Secret de Meta (para verificar firma HMAC)
WHATSAPP_PHONE_NUMBER_ID=    # ID del número en WhatsApp Business Manager
WHATSAPP_ACCESS_TOKEN=       # Token permanente de System User

# ─── Instagram (mismo token Meta) ────────────────────────────
INSTAGRAM_ACCESS_TOKEN=      # Token de Instagram Business API
INSTAGRAM_PAGE_ID=           # ID de la página de Instagram

# ─── Email — Gmail ────────────────────────────────────────────
GMAIL_CLIENT_ID=             # De Google Cloud Console → OAuth 2.0
GMAIL_CLIENT_SECRET=         # Secreto del cliente OAuth
GMAIL_REDIRECT_URI=          # https://tu-app.up.railway.app/api/auth/gmail/callback

# ─── Email — Outlook ─────────────────────────────────────────
OUTLOOK_CLIENT_ID=           # De Azure Active Directory → App registrations
OUTLOOK_CLIENT_SECRET=       # Secreto del cliente de Azure
OUTLOOK_REDIRECT_URI=        # https://tu-app.up.railway.app/api/auth/outlook/callback

# ─── Google Calendar ─────────────────────────────────────────
GOOGLE_CLIENT_ID=            # De Google Cloud Console → OAuth 2.0
GOOGLE_CLIENT_SECRET=        # Secreto del cliente OAuth
GOOGLE_REDIRECT_URI=         # https://tu-app.up.railway.app/api/calendar/callback

# ─── IA ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # API key de Anthropic

# ─── Texto a voz ─────────────────────────────────────────────
ELEVENLABS_API_KEY=          # API key de ElevenLabs
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Rachel (por defecto)

# ─── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=                # URL del proyecto Supabase
SUPABASE_SERVICE_KEY=        # Service Role Key (nunca en el cliente)

# ─── PWA Push Notifications ──────────────────────────────────
VAPID_PUBLIC_KEY=            # Generar con: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
OWNER_EMAIL=                 # Tu email (requerido por VAPID)

# ─── App ─────────────────────────────────────────────────────
NEXUS_USER_ID=               # UUID del usuario en la tabla users (Supabase)
OWNER_WA_ID=                 # Tu número WA sin + ni espacios (ej: 5491112345678)
COST_LIMIT_DAILY_USD=10      # Límite diario de gasto en IA (default: 10)
COST_ALERT_PCT=80            # % al que llega la alerta (default: 80)
PORT=3000
